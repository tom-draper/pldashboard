# Copy to .env and fill in. All values are required.

# Current Premier League season (the year the season started in)
SEASON=2025

# football-data.org API
URL=https://api.football-data.org/
X_AUTH_TOKEN=your-football-data-api-token

# MongoDB Atlas credentials
MONGODB_USERNAME=your-username
MONGODB_PASSWORD=your-password
MONGODB_DATABASE=PremierLeague

# Optional: collection holding score predictions. Defaults to Predictions2024.
# MONGODB_PREDICTIONS_COLLECTION=Predictions2024
